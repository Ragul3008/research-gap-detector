# .env.example
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ─── Gemini API Key (required for AI explanations) ───
# Get your free key at: https://aistudio.google.com
GEMINI_API_KEY=your_api_key_here

# ─── Embedding Model ────────────────────────────────
# BAAI/bge-large-en-v1.5  → best quality (~1.3 GB)
# all-MiniLM-L6-v2        → lightweight & fast (~90 MB)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ─── API Settings ────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ─── Logging ─────────────────────────────────────────
LOG_LEVEL=INFO
